# Runtime
NODE_ENV=development
PORT=5000
LOG_LEVEL=info

# Supabase client (exposed to browser via Vite)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase server (private)
# Server code prefers SUPABASE_URL and falls back to VITE_SUPABASE_URL.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Optional integrations
VITE_STRIPE_PUBLIC_KEY=
VITE_R2_PUBLIC_BASE_URL=

# Public base URL of the deployed app, used to build Dodo return_url / cancel_url,
# canonical URLs in sitemap.xml / robots.txt, and Stripe-style redirects.
# Locally: http://localhost:5000  |  Prod: https://app.scoremax.com (no trailing slash).
APP_BASE_URL=http://localhost:5000

# Dodo Payments (server-side only)
# Generate API + webhook keys in Dashboard → Developer.
# Use the *test_mode* key during development; switch to live_mode in prod.
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_WEBHOOK_KEY=
DODO_PAYMENTS_ENVIRONMENT=test_mode

# Dodo product ids (Dashboard → Products → copy `prod_...`)
# These must be subscription products priced at 24,80 € / month and 178 € / year.
DODO_PRODUCT_ID_MONTHLY=
DODO_PRODUCT_ID_YEARLY=

# Cloudflare R2 (private server-side credentials)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

SCOREMAX_API_KEY=ta_clé_scoremax
SCOREMAX_API_BASE_URL=https://api.scoremax.com
SCOREMAX_API_TIMEOUT_MS=30000
