# Runtime
NODE_ENV=development
PORT=5000
LOG_LEVEL=info

# Supabase client (exposed to browser via Vite)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase server (private)
# Server code prefers SUPABASE_URL and falls back to VITE_SUPABASE_URL.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Optional integrations
VITE_STRIPE_PUBLIC_KEY=

SCOREMAX_API_KEY=ta_clé_scoremax
SCOREMAX_API_URL=https://api.scoremax.com
SCOREMAX_API_TIMEOUT_MS=30000
